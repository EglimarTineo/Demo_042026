<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_sumitic_ve" model="ir.ui.view">
        <field name="name">res.partner.form.sumitic.ve</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            
            <xpath expr="//div[@class='o_address_format']" position="replace">
                <div class="o_address_format">
                    <field name="street" placeholder="Calle/Av, Edificio, Casa..." class="o_address_street"/>
                    <field name="street2" placeholder="Punto de referencia o urbanización" class="o_address_street"/>
                    <field name="city" placeholder="Ciudad" class="o_address_city"/>
                    
                    <field name="state_id" class="o_address_state" placeholder="Estado" 
                           options="{'no_open': True, 'no_create': True}" 
                           context="{'country_id': country_id}"/>
                    
                    <field name="municipality_id" placeholder="Municipio" 
                           domain="[('state_id', '=', state_id)]"
                           options="{'no_open': True, 'no_create': True}"
                           invisible="not state_id"/>
                    
                    <field name="parish_id" placeholder="Parroquia" 
                           domain="[('municipality_id', '=', municipality_id)]"
                           options="{'no_open': True, 'no_create': True}"
                           invisible="not municipality_id"/>
                    
                    <field name="zip" placeholder="Código Postal" class="o_address_zip"/>
                    <field name="country_id" placeholder="País" class="o_address_country" 
                           options="{'no_open': True, 'no_create': True}"/>
                </div>
            </xpath>

            <xpath expr="//field[@name='vat']" position="attributes">
                <attribute name="string">RIF</attribute>
                <attribute name="placeholder">Ej: J123456789</attribute>
            </xpath>

            <xpath expr="//group[@name='misc']" position="inside">
                <field name="l10n_ve_responsibility_type_id" 
                       string="Tipo de Contribuyente" 
                       options="{'no_open': True, 'no_create': True}"/>
            </xpath>

        </field>
    </record>
</odoo>
